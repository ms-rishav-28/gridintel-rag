# POWERGRID RAG Backend Environment Configuration

# ──────────────────────────────────────────────────
#  APPLICATION
# ──────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────
#  LLM PROVIDERS (at least one required)
# ──────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Default LLM Configuration
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────
#  CORS / FRONTEND
# ──────────────────────────────────────────────────
# Set this to your deployed Vercel URL
FRONTEND_URL=https://your-app.vercel.app

# ──────────────────────────────────────────────────
#  CONVEX
# ──────────────────────────────────────────────────
CONVEX_URL=
# Optional admin token for server-to-server mutations/queries
CONVEX_ADMIN_KEY=

# ──────────────────────────────────────────────────
#  VECTOR DATABASE
# ──────────────────────────────────────────────────
# CODEX-FIX: LanceDB must point at the Railway persistent volume.
LANCEDB_PATH=/data/lancedb

# ──────────────────────────────────────────────────
#  EMBEDDING MODEL
# ──────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ──────────────────────────────────────────────────
#  DOCUMENT PROCESSING
# ──────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ──────────────────────────────────────────────────
#  SECURITY
# ──────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
BACKEND_API_KEY=
MAX_REQUEST_BODY_MB=55

# Trust x-forwarded-for/x-real-ip headers only when behind a known proxy.
TRUST_PROXY_HEADERS=false
# Optional comma-separated list of trusted proxy IPs/CIDRs (example: 127.0.0.1,10.0.0.0/8)
TRUSTED_PROXY_IPS=

# Response hardening headers
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=true
HSTS_MAX_AGE_SECONDS=31536000

# Optional: per-IP+path API rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
