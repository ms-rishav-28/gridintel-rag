# CODEX-FIX: production env template aligned with the Railway, Convex, LanceDB, and Vercel contract.

# -- App -----------------------------------------------------------------------
ENVIRONMENT=production
SECRET_KEY=replace-with-64-random-chars
LOG_LEVEL=INFO
BACKEND_API_KEY=replace-with-strong-random-key
FRONTEND_URL=https://your-app.vercel.app

# -- Convex (required for persistent storage) ----------------------------------
CONVEX_URL=https://your-project.convex.cloud
CONVEX_ADMIN_KEY=your-convex-admin-key

# -- LanceDB (vector index - set to Railway persistent volume path) ------------
LANCEDB_PATH=/data/lancedb
LANCEDB_CONFIG_DIR=/data/lancedb_config

# -- Embedding model -----------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# -- Vision model --------------------------------------------------------------
VISION_MODEL=microsoft/Florence-2-base
ENABLE_VISION=true

# -- LLM providers -------------------------------------------------------------
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
HF_API_TOKEN=your-huggingface-token

# -- Document ingestion --------------------------------------------------------
MAX_UPLOAD_SIZE_MB=150
MAX_REQUEST_BODY_MB=155
ENABLE_BROWSER_INGESTION=false
URL_CACHE_TTL_HOURS=24

# -- Rate limiting -------------------------------------------------------------
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# -- Security ------------------------------------------------------------------
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=true
TRUST_PROXY_HEADERS=true
