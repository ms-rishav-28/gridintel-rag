# POWERGRID RAG Backend Environment Configuration

# ──────────────────────────────────────────────────
#  APPLICATION
# ──────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────
#  LLM PROVIDERS (at least one required)
# ──────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Default LLM Configuration
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────
#  CORS / FRONTEND
# ──────────────────────────────────────────────────
# Set this to your deployed Vercel URL
FRONTEND_URL=https://your-app.vercel.app

# ──────────────────────────────────────────────────
#  CONVEX
# ──────────────────────────────────────────────────
CONVEX_URL=
# Optional admin token for server-to-server mutations/queries
CONVEX_ADMIN_KEY=

# ──────────────────────────────────────────────────
#  VECTOR DATABASE
# ──────────────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=powergrid_docs

# ──────────────────────────────────────────────────
#  EMBEDDING MODEL
# ──────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ──────────────────────────────────────────────────
#  DOCUMENT PROCESSING
# ──────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ──────────────────────────────────────────────────
#  SECURITY
# ──────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
BACKEND_API_KEY=

# Optional: per-IP+path API rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
